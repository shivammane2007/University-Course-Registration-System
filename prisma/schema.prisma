// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Administrator {
  admin_id   Int      @id @default(autoincrement())
  user_id    String   @unique @db.VarChar(50)
  password   String   @db.VarChar(255)
  created_at DateTime @default(now())

  courses    Course[]

  @@map("administrators")
}

model Department {
  dept_id   Int    @id @default(autoincrement())
  dept_name String @db.VarChar(100)

  faculties Faculty[]
  students  Student[]
  courses   Course[]

  @@map("departments")
}

model Faculty {
  faculty_id  Int      @id @default(autoincrement())
  user_id     String   @unique @db.VarChar(50)
  password    String   @db.VarChar(255)
  first_name  String   @db.VarChar(50)
  last_name   String   @db.VarChar(50)
  dob         DateTime @db.Date
  gender      Gender
  address     String   @db.Text
  domain      String   @db.VarChar(100)
  designation String   @db.VarChar(100)
  contact_no  String   @db.VarChar(15)
  dept_id     Int
  created_at  DateTime @default(now())

  department    Department      @relation(fields: [dept_id], references: [dept_id])
  courseFaculty CourseFaculty[]

  @@map("faculties")
}

model Student {
  student_id    Int      @id @default(autoincrement())
  user_id       String   @unique @db.VarChar(50)
  password      String   @db.VarChar(255)
  first_name    String   @db.VarChar(50)
  last_name     String   @db.VarChar(50)
  dob           DateTime @db.Date
  gender        Gender
  phone_no      String   @db.VarChar(15)
  city          String   @db.VarChar(80)
  state         String   @db.VarChar(80)
  pincode       String   @db.VarChar(10)
  year_enrolled Int      @db.Year
  dept_id       Int
  created_at    DateTime @default(now())

  department Department  @relation(fields: [dept_id], references: [dept_id])
  enrolments Enrolment[]

  @@map("students")
}

model Course {
  course_id    Int      @id @default(autoincrement())
  course_name  String   @db.VarChar(150)
  dept_id      Int
  duration     String   @db.VarChar(50)
  mode         CourseMode
  platform     String?  @db.VarChar(100)
  college_name String?  @db.VarChar(150)
  timing       String   @db.VarChar(100)
  created_by   Int
  created_at   DateTime @default(now())

  department    Department      @relation(fields: [dept_id], references: [dept_id])
  admin         Administrator   @relation(fields: [created_by], references: [admin_id])
  enrolments    Enrolment[]
  courseFaculty CourseFaculty[]

  @@map("courses")
}

model CourseFaculty {
  id         Int @id @default(autoincrement())
  course_id  Int
  faculty_id Int

  course  Course  @relation(fields: [course_id], references: [course_id])
  faculty Faculty @relation(fields: [faculty_id], references: [faculty_id])

  @@unique([course_id, faculty_id])
  @@map("course_faculty")
}

model Enrolment {
  enrolment_id Int            @id @default(autoincrement())
  student_id   Int
  course_id    Int
  status       EnrolmentStatus @default(Pending)
  enrolled_at  DateTime       @default(now())

  student Student @relation(fields: [student_id], references: [student_id])
  course  Course  @relation(fields: [course_id], references: [course_id])

  @@unique([student_id, course_id])
  @@map("enrolments")
}

enum Gender {
  Male
  Female
  Other
}

enum CourseMode {
  Online
  Offline
}

enum EnrolmentStatus {
  Pending
  Approved
  Dropped
}
